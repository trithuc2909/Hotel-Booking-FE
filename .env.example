# API Backend URL
# Local: http://localhost:3001/api/v1
# Dev: https://hotel-api-dev.railway.app/api/v1
# Prod: https://api.hotel.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# App Info
NEXT_PUBLIC_APP_NAME=BullManHotel
NEXT_PUBLIC_APP_VERSION=1.0.0
# Environment
NODE_ENV=development